# Copy this file to .env.local for local development, or set these in the
# AWS Amplify console (App settings -> Environment variables) for deploys.
# Until NEXT_PUBLIC_AWS_API_URL is set, the app runs fully on simulated data
# — see src/utils/api.js for the fallback logic and in-app toast notices.

# API Gateway invoke URL (e.g. https://abc123.execute-api.us-east-1.amazonaws.com/prod)
# Consumed by src/utils/api.js for submitOrder(), fetchOrders(), and
# updateOrderStatus().
NEXT_PUBLIC_AWS_API_URL=

# UI-level password for the /admin dashboard gate. This is NOT real
# authentication — see the note in src/components/admin/PasswordGate.jsx.
NEXT_PUBLIC_ADMIN_PASSWORD=ubuntu2026
