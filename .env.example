# Copy this file to .env.local and fill in real values once the AWS
# backend exists. Until then, the app falls back to simulated data — see
# src/utils/api.js for the fallback logic.

# API Gateway invoke URL (e.g. https://abc123.execute-api.us-east-1.amazonaws.com/prod)
# Consumed by src/utils/api.js for submitOrder() and fetchOrders().
NEXT_PUBLIC_API_BASE_URL=

# UI-level password for the /admin dashboard gate. This is NOT real
# authentication — see the note in src/components/admin/PasswordGate.jsx.
NEXT_PUBLIC_ADMIN_PASSWORD=ubuntu2026
